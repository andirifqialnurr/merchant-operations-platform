{
  "name": "merchant-operations-platform",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "db:deploy": "pnpm --filter @merchant/database db:deploy",
    "db:format": "pnpm --filter @merchant/database db:format",
    "db:generate": "pnpm --filter @merchant/database db:generate",
    "db:migrate": "pnpm --filter @merchant/database db:migrate",
    "db:push": "pnpm --filter @merchant/database db:push",
    "db:setup": "pnpm run db:generate && pnpm run db:deploy",
    "db:status": "pnpm --filter @merchant/database db:status",
    "db:studio": "pnpm --filter @merchant/database db:studio",
    "db:validate": "pnpm --filter @merchant/database db:validate",
    "lint": "turbo run lint && node scripts/check-color-guardrails.mjs",
    "lint:colors": "node scripts/check-color-guardrails.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:components": "turbo run test --filter=@merchant/ui",
    "test:e2e": "turbo run test:e2e --filter=@merchant/storybook",
    "build:storybook": "turbo run build --filter=@merchant/storybook",
    "format:check": "turbo run format:check"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "turbo": "2.10.4",
    "typescript": "6.0.3"
  }
}
