{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@merchant/typescript-config/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ES2024"
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "playwright.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "storybook-static"]
}
