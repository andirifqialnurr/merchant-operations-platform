generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum PlatformRole {
  OWNER
  ADMIN
  SUPPORT
}

enum OrganizationUnitStatus {
  ACTIVE
  INACTIVE
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

enum ModuleKind {
  CORE
  COMMERCIAL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE
  SUSPENDED
  TERMINATED
}

enum CatalogRecordStatus {
  ACTIVE
  INACTIVE
}

enum ProductAvailability {
  AVAILABLE
  SOLD_OUT
}

enum ModifierSelectionType {
  SINGLE
  MULTIPLE
}

model User {
  id                String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email             String             @unique @db.VarChar(254)
  passwordHash      String             @map("password_hash") @db.VarChar(255)
  displayName       String             @map("display_name") @db.VarChar(160)
  status            UserStatus         @default(ACTIVE)
  passwordChangedAt DateTime           @default(now()) @map("password_changed_at") @db.Timestamptz(6)
  lastLoginAt       DateTime?          @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  loginSessions     LoginSession[]
  tenantMemberships TenantMembership[]

  @@map("users")
}

model PlatformUser {
  id                String                 @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email             String                 @unique @db.VarChar(254)
  passwordHash      String                 @map("password_hash") @db.VarChar(255)
  displayName       String                 @map("display_name") @db.VarChar(160)
  role              PlatformRole
  status            UserStatus             @default(ACTIVE)
  passwordChangedAt DateTime               @default(now()) @map("password_changed_at") @db.Timestamptz(6)
  lastLoginAt       DateTime?              @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  loginSessions     PlatformLoginSession[]

  @@index([role, status])
  @@map("platform_users")
}

model PlatformLoginSession {
  id         String       @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  tokenHash  String       @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime     @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime?    @map("revoked_at") @db.Timestamptz(6)
  lastSeenAt DateTime     @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  ipAddress  String?      @map("ip_address") @db.VarChar(45)
  userAgent  String?      @map("user_agent") @db.VarChar(512)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user       PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("platform_login_sessions")
}

model LoginSession {
  id         String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  lastSeenAt DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  userAgent  String?   @map("user_agent") @db.VarChar(512)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("login_sessions")
}

model Tenant {
  id                           String                        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name                         String                        @db.VarChar(160)
  slug                         String                        @unique @db.VarChar(80)
  status                       OrganizationUnitStatus        @default(ACTIVE)
  createdAt                    DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  brands                       Brand[]
  outlets                      Outlet[]
  auditLogs                    AuditLog[]
  idempotencyKeys              IdempotencyKey[]
  outboxEvents                 OutboxEvent[]
  memberships                  TenantMembership[]
  roles                        Role[]
  subscriptions                Subscription[]
  entitlements                 TenantEntitlement[]
  catalogCategories            CatalogCategory[]
  catalogProducts              CatalogProduct[]
  catalogProductVariants       CatalogProductVariant[]
  catalogModifierGroups        CatalogModifierGroup[]
  catalogModifierOptions       CatalogModifierOption[]
  catalogProductModifierGroups CatalogProductModifierGroup[]
  catalogProductImages         CatalogProductImage[]

  @@map("tenants")
}

model Brand {
  id        String                 @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId  String                 @map("tenant_id") @db.Uuid
  name      String                 @db.VarChar(160)
  slug      String                 @db.VarChar(80)
  status    OrganizationUnitStatus @default(ACTIVE)
  createdAt DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlets   Outlet[]

  @@unique([tenantId, slug])
  @@unique([tenantId, id])
  @@index([tenantId, createdAt])
  @@map("brands")
}

model Outlet {
  id              String                 @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String                 @map("tenant_id") @db.Uuid
  brandId         String                 @map("brand_id") @db.Uuid
  code            String                 @db.VarChar(40)
  name            String                 @db.VarChar(160)
  timezone        String                 @default("Asia/Jakarta") @db.VarChar(64)
  status          OrganizationUnitStatus @default(ACTIVE)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  brand           Brand                  @relation(fields: [tenantId, brandId], references: [tenantId, id], onDelete: Restrict)
  auditLogs       AuditLog[]
  idempotencyKeys IdempotencyKey[]
  outboxEvents    OutboxEvent[]
  assignments     OutletAssignment[]

  @@unique([tenantId, code])
  @@unique([tenantId, id])
  @@index([tenantId, brandId])
  @@index([tenantId, createdAt])
  @@map("outlets")
}

model CatalogCategory {
  id           String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  name         String              @db.VarChar(160)
  slug         String              @db.VarChar(80)
  displayOrder Int                 @default(0) @map("display_order")
  status       CatalogRecordStatus @default(ACTIVE)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  products     CatalogProduct[]

  @@unique([tenantId, slug])
  @@unique([tenantId, id])
  @@index([tenantId, status, displayOrder])
  @@map("categories")
}

model CatalogProduct {
  id             String                        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId       String                        @map("tenant_id") @db.Uuid
  categoryId     String                        @map("category_id") @db.Uuid
  name           String                        @db.VarChar(160)
  slug           String                        @db.VarChar(80)
  description    String?                       @db.VarChar(2000)
  basePriceMinor BigInt                        @map("base_price_minor") @db.BigInt
  currency       String                        @default("IDR") @db.Char(3)
  availability   ProductAvailability           @default(AVAILABLE)
  status         CatalogRecordStatus           @default(ACTIVE)
  createdAt      DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant         Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category       CatalogCategory               @relation(fields: [tenantId, categoryId], references: [tenantId, id], onDelete: Restrict)
  variants       CatalogProductVariant[]
  modifierGroups CatalogProductModifierGroup[]
  images         CatalogProductImage[]

  @@unique([tenantId, slug])
  @@unique([tenantId, id])
  @@index([tenantId, categoryId, status])
  @@index([tenantId, availability, status])
  @@map("products")
}

model CatalogProductVariant {
  id              String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  productId       String              @map("product_id") @db.Uuid
  name            String              @db.VarChar(160)
  priceDeltaMinor BigInt              @default(0) @map("price_delta_minor") @db.BigInt
  availability    ProductAvailability @default(AVAILABLE)
  displayOrder    Int                 @default(0) @map("display_order")
  status          CatalogRecordStatus @default(ACTIVE)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product         CatalogProduct      @relation(fields: [tenantId, productId], references: [tenantId, id], onDelete: Restrict)

  @@unique([tenantId, id])
  @@unique([tenantId, productId, name])
  @@index([tenantId, productId, status, displayOrder])
  @@map("product_variants")
}

model CatalogModifierGroup {
  id            String                        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String                        @map("tenant_id") @db.Uuid
  name          String                        @db.VarChar(160)
  selectionType ModifierSelectionType         @default(SINGLE) @map("selection_type")
  minSelections Int                           @default(0) @map("min_selections")
  maxSelections Int                           @default(1) @map("max_selections")
  displayOrder  Int                           @default(0) @map("display_order")
  status        CatalogRecordStatus           @default(ACTIVE)
  createdAt     DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant        Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  options       CatalogModifierOption[]
  productLinks  CatalogProductModifierGroup[]

  @@unique([tenantId, id])
  @@unique([tenantId, name])
  @@index([tenantId, status, displayOrder])
  @@map("modifier_groups")
}

model CatalogModifierOption {
  id              String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  groupId         String               @map("group_id") @db.Uuid
  name            String               @db.VarChar(160)
  priceDeltaMinor BigInt               @default(0) @map("price_delta_minor") @db.BigInt
  availability    ProductAvailability  @default(AVAILABLE)
  displayOrder    Int                  @default(0) @map("display_order")
  status          CatalogRecordStatus  @default(ACTIVE)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  group           CatalogModifierGroup @relation(fields: [tenantId, groupId], references: [tenantId, id], onDelete: Restrict)

  @@unique([tenantId, id])
  @@unique([tenantId, groupId, name])
  @@index([tenantId, groupId, status, displayOrder])
  @@map("modifier_options")
}

model CatalogProductModifierGroup {
  id              String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  productId       String               @map("product_id") @db.Uuid
  modifierGroupId String               @map("modifier_group_id") @db.Uuid
  displayOrder    Int                  @default(0) @map("display_order")
  status          CatalogRecordStatus  @default(ACTIVE)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product         CatalogProduct       @relation(fields: [tenantId, productId], references: [tenantId, id], onDelete: Restrict)
  modifierGroup   CatalogModifierGroup @relation(fields: [tenantId, modifierGroupId], references: [tenantId, id], onDelete: Restrict)

  @@unique([tenantId, id])
  @@unique([tenantId, productId, modifierGroupId])
  @@index([tenantId, productId, status, displayOrder])
  @@index([tenantId, modifierGroupId, status])
  @@map("product_modifier_groups")
}

model CatalogProductImage {
  id           String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  productId    String              @map("product_id") @db.Uuid
  objectKey    String              @map("object_key") @db.VarChar(512)
  contentType  String              @map("content_type") @db.VarChar(100)
  altText      String?             @map("alt_text") @db.VarChar(300)
  width        Int?
  height       Int?
  isPrimary    Boolean             @default(false) @map("is_primary")
  displayOrder Int                 @default(0) @map("display_order")
  status       CatalogRecordStatus @default(ACTIVE)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product      CatalogProduct      @relation(fields: [tenantId, productId], references: [tenantId, id], onDelete: Restrict)

  @@unique([tenantId, id])
  @@unique([tenantId, objectKey])
  @@index([tenantId, productId, status, displayOrder])
  @@map("product_images")
}

model TenantMembership {
  id          String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  status      MembershipStatus   @default(ACTIVE)
  allOutlets  Boolean            @default(false) @map("all_outlets")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user        User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  roles       UserRole[]
  assignments OutletAssignment[]

  @@unique([tenantId, userId])
  @@unique([tenantId, id])
  @@index([userId, status])
  @@map("tenant_memberships")
}

model Permission {
  key         String           @id @db.VarChar(120)
  description String           @db.VarChar(255)
  roleLinks   RolePermission[]

  @@map("permissions")
}

model Role {
  id          String                 @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String                 @map("tenant_id") @db.Uuid
  code        String                 @db.VarChar(80)
  name        String                 @db.VarChar(160)
  isSystem    Boolean                @default(false) @map("is_system")
  status      OrganizationUnitStatus @default(ACTIVE)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  permissions RolePermission[]
  userLinks   UserRole[]

  @@unique([tenantId, code])
  @@unique([tenantId, id])
  @@index([tenantId, status, createdAt])
  @@map("roles")
}

model RolePermission {
  tenantId      String     @map("tenant_id") @db.Uuid
  roleId        String     @map("role_id") @db.Uuid
  permissionKey String     @map("permission_key") @db.VarChar(120)
  role          Role       @relation(fields: [tenantId, roleId], references: [tenantId, id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Restrict)

  @@id([tenantId, roleId, permissionKey])
  @@index([permissionKey])
  @@map("role_permissions")
}

model UserRole {
  tenantId     String           @map("tenant_id") @db.Uuid
  membershipId String           @map("membership_id") @db.Uuid
  roleId       String           @map("role_id") @db.Uuid
  membership   TenantMembership @relation(fields: [tenantId, membershipId], references: [tenantId, id], onDelete: Cascade)
  role         Role             @relation(fields: [tenantId, roleId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, membershipId, roleId])
  @@index([tenantId, roleId])
  @@map("user_roles")
}

model OutletAssignment {
  tenantId     String           @map("tenant_id") @db.Uuid
  membershipId String           @map("membership_id") @db.Uuid
  outletId     String           @map("outlet_id") @db.Uuid
  membership   TenantMembership @relation(fields: [tenantId, membershipId], references: [tenantId, id], onDelete: Cascade)
  outlet       Outlet           @relation(fields: [tenantId, outletId], references: [tenantId, id], onDelete: Cascade)

  @@id([tenantId, membershipId, outletId])
  @@index([tenantId, outletId])
  @@map("outlet_assignments")
}

model ModuleDefinition {
  key          String                 @id @db.VarChar(80)
  name         String                 @db.VarChar(160)
  kind         ModuleKind
  status       OrganizationUnitStatus @default(ACTIVE)
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  planLinks    PlanModule[]
  entitlements TenantEntitlement[]
  dependencies ModuleDependency[]     @relation("ModuleDependencies")
  dependents   ModuleDependency[]     @relation("ModuleDependents")

  @@index([kind, status])
  @@map("modules")
}

model ModuleDependency {
  moduleKey     String           @map("module_key") @db.VarChar(80)
  dependencyKey String           @map("dependency_key") @db.VarChar(80)
  module        ModuleDefinition @relation("ModuleDependencies", fields: [moduleKey], references: [key], onDelete: Cascade)
  dependency    ModuleDefinition @relation("ModuleDependents", fields: [dependencyKey], references: [key], onDelete: Restrict)

  @@id([moduleKey, dependencyKey])
  @@index([dependencyKey])
  @@map("module_dependencies")
}

model Plan {
  id            String                 @id @default(dbgenerated("uuidv7()")) @db.Uuid
  code          String                 @unique @db.VarChar(80)
  name          String                 @db.VarChar(160)
  status        OrganizationUnitStatus @default(ACTIVE)
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  modules       PlanModule[]
  subscriptions Subscription[]

  @@index([status, createdAt])
  @@map("plans")
}

model PlanModule {
  planId    String           @map("plan_id") @db.Uuid
  moduleKey String           @map("module_key") @db.VarChar(80)
  plan      Plan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  module    ModuleDefinition @relation(fields: [moduleKey], references: [key], onDelete: Restrict)

  @@id([planId, moduleKey])
  @@index([moduleKey])
  @@map("plan_modules")
}

model Subscription {
  id           String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  planId       String             @map("plan_id") @db.Uuid
  status       SubscriptionStatus
  startsAt     DateTime           @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime?          @map("ends_at") @db.Timestamptz(6)
  graceEndsAt  DateTime?          @map("grace_ends_at") @db.Timestamptz(6)
  supersededAt DateTime?          @map("superseded_at") @db.Timestamptz(6)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plan         Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([planId, status])
  @@map("subscriptions")
}

model TenantEntitlement {
  id          String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  moduleKey   String           @map("module_key") @db.VarChar(80)
  enabled     Boolean
  reason      String           @db.VarChar(500)
  effectiveAt DateTime         @default(now()) @map("effective_at") @db.Timestamptz(6)
  actorId     String?          @map("actor_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  module      ModuleDefinition @relation(fields: [moduleKey], references: [key], onDelete: Restrict)

  @@unique([tenantId, moduleKey])
  @@index([moduleKey, enabled])
  @@map("tenant_entitlements")
}

model AuditLog {
  id         String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  outletId   String?  @map("outlet_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String   @db.VarChar(120)
  entityType String   @map("entity_type") @db.VarChar(120)
  entityId   String?  @map("entity_id") @db.Uuid
  requestId  String?  @map("request_id") @db.VarChar(100)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlet     Outlet?  @relation(fields: [outletId], references: [id], onDelete: Restrict)

  @@index([tenantId, outletId, createdAt])
  @@index([tenantId, entityType, entityId, createdAt])
  @@map("audit_logs")
}

model IdempotencyKey {
  id             String            @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  outletId       String            @map("outlet_id") @db.Uuid
  scope          String            @db.VarChar(120)
  key            String            @db.VarChar(255)
  requestHash    String?           @map("request_hash") @db.VarChar(128)
  status         IdempotencyStatus @default(PENDING)
  responseStatus Int?              @map("response_status")
  responseBody   Json?             @map("response_body")
  expiresAt      DateTime          @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlet         Outlet            @relation(fields: [outletId], references: [id], onDelete: Restrict)

  @@unique([tenantId, outletId, scope, key])
  @@index([tenantId, outletId, expiresAt])
  @@map("idempotency_keys")
}

model OutboxEvent {
  id            String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  outletId      String?   @map("outlet_id") @db.Uuid
  type          String    @db.VarChar(160)
  aggregateType String    @map("aggregate_type") @db.VarChar(120)
  aggregateId   String    @map("aggregate_id") @db.Uuid
  payload       Json
  occurredAt    DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  availableAt   DateTime  @default(now()) @map("available_at") @db.Timestamptz(6)
  processedAt   DateTime? @map("processed_at") @db.Timestamptz(6)
  attemptCount  Int       @default(0) @map("attempt_count")
  lastError     String?   @map("last_error") @db.Text
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  outlet        Outlet?   @relation(fields: [outletId], references: [id], onDelete: Restrict)

  @@index([tenantId, outletId, occurredAt])
  @@index([processedAt, availableAt])
  @@map("outbox_events")
}
